# ScoutAI Worker
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret — ScoutAI sends this header, worker validates it
WORKER_SECRET=change-me-to-a-random-string

# ScoutAI base URL — worker POSTs results back here
SCOUTAI_URL=https://scoutai.site
SCOUTAI_WEBHOOK_SECRET=change-me-to-another-random-string

# Port
PORT=3001

# Playwright — set to "true" to run headed (for debugging)
PLAYWRIGHT_HEADLESS=true

# Rate limiting
MAX_CONCURRENT_BROWSERS=2
JOB_TIMEOUT_MS=120000
